// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
    "name": "cv_ranking",
    // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
    "build": {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers-contrib/features/poetry:2": {},
    },
    // Use 'postCreateCommand' to run commands after the container is created.
    "postCreateCommand": "bash .devcontainer/postCreateCommand.sh",
    // Disable __pycache__ generation
    "containerEnv": {
        "PYTHONDONTWRITEBYTECODE": "1"
    },
    // Configure tool-specific properties.
    "customizations": {
        "vscode": {
            "extensions": ["ms-python.python", "editorconfig.editorconfig"],
            "settings": {
                "python.testing.pytestArgs": ["tests"],
                "python.testing.unittestEnabled": false,
                "python.testing.pytestEnabled": true,
                "python.defaultInterpreterPath": "/workspaces/cv_ranking/.venv/bin/python",
                "python.testing.pytestPath": "/workspaces/cv_ranking/.venv/bin/pytest"
            }
        }
    },
    "shutdownAction": "none"
}
