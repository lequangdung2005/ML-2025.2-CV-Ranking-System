# Kaggle API Credentials
# Get your username and API key from https://www.kaggle.com/settings/account
# Steps:
# 1. Go to Kaggle website and log in
# 2. Click on "Account" in the left menu
# 3. Scroll down to "API" section
# 4. Click "Create New API Token" - this downloads kaggle.json
# 5. Open kaggle.json and copy the values below
KAGGLE_USERNAME=ten
KAGGLE_API_KEY=password

# HuggingFace API Token
# Get your API token from https://huggingface.co/settings/tokens
# Steps:
# 1. Go to HuggingFace website and log in
# 2. Click on your profile icon (top right)
# 3. Select "Settings"
# 4. Click on "Access Tokens" in the left menu
# 5. Create a new token with "read" permission
# 6. Copy the token value below
HUGGINGFACE_API_TOKEN=hf_dienvaoday

# Alternative HuggingFace token variable name (optional, either HF_TOKEN or HUGGINGFACE_API_TOKEN works)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
